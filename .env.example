# Copy this file to .env and fill in your values

# Required: OpenAI API key for running evaluations
OPENAI_API_KEY=your_openai_api_key_here

# Optional: custom base URL (e.g. for Azure or proxy)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: override prediction file paths
# Default paths assume files are placed under data/predictions/
# Download from HuggingFace: https://huggingface.co/datasets/XingYuSSS/ESC-Pro
#
# LLAMA_BASE_PREDICTIONS=data/predictions/llama_base.jsonl
# LLAMA_COGNITIVE_PREDICTIONS=data/predictions/llama_cognitive.jsonl
# QWEN_BASE_PREDICTIONS=data/predictions/qwen_base.jsonl
# QWEN_COGNITIVE_PREDICTIONS=data/predictions/qwen_cognitive.jsonl
# GPT4O_PREDICTIONS=data/predictions/gpt4o.jsonl
# CLAUDE_PREDICTIONS=data/predictions/claude_sonnet.jsonl
# GPT4O_MINI_PREDICTIONS=data/predictions/gpt4o_mini.jsonl
